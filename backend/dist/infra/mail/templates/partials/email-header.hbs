<table width='100%' cellpadding='0' cellspacing='0' style='background:#f8f8f8;'>
  <tr>
    <td align='center' style='padding:20px 0;'>

      <!-- Container central -->
      <table cellpadding='0' cellspacing='0' align='center'>

        <!-- Linha dos Logos -->
        <tr>
          <td align='center'>
            <table cellpadding='0' cellspacing='0'>
              <tr>
                <td align='right' style='padding:0 15px;'>
                  <img
                    src='{{logoCISRU}}'
                    alt='CISRU'
                    width='150'
                    style='display:block;border:0;outline:none;text-decoration:none;'
                  />
                </td>

                <td align='left' style='padding:0 15px;'>
                  <img
                    src='{{logoSAMU}}'
                    alt='OI SAMU'
                    width='150'
                    style='display:block;border:0;outline:none;text-decoration:none;'
                  />
                </td>
              </tr>
            </table>
          </td>
        </tr>

        <!-- Título -->
        <tr>
          <td align='center' style='padding-top:15px;'>
            <div
              style='font-size:22px;font-weight:500;line-height:26px;text-align:center;color:#333333;'
            >
              Plataforma OI SAMU
            </div>
          </td>
        </tr>

      </table>

    </td>
  </tr>
</table>